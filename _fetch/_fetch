#! /hint/sh
${shell_is_interactive-return}



unset-unseted-i
	shuf_1_toi "$B"/_fetch/[a-z]*[!%~] || return
	_fetch=$i
unset-seted-i

( . "$_fetch" ) >&2

case ${_fetch##*/} in
16|color-eudaldgr|fetchName|fetchName-2|_fetch.sh|%nofetch)
PS1-ash;;

mini-colors)
PS1--;;
esac

